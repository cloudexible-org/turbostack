{
  "name": "turbostack",
  "version": "3.0.2",
  "private": true,
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "prepare": "lefthook install",
    "build": "turbo build",
    "dev": "turbo dev --ui tui",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test --filter=!e2e",
    "format": "biome format . --write",
    "check": "biome check .",
    "storybook": "pnpm --filter @repo/ui storybook",
    "setup:envs": "node scripts/setup.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "lefthook": "^2.1.9",
    "portless": "^0.15.0",
    "turbo": "latest",
    "turbo-ignore": "^2.9.18",
    "typescript": "catalog:"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@clerk/shared",
      "esbuild",
      "sharp"
    ]
  },
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=24"
  }
}
